# ============================================
# 多模态 RAG + Prompt 策略评估平台 — 环境变量配置
# ============================================
# 使用方法: 复制此文件为 .env，然后填写下方带 [必填] 的值
#    cp .env.example .env
# ============================================

# --- LLM (智谱 GLM — 文本) ---
OPENAI_API_KEY=你的智谱API_KEY          # [必填] 从 https://open.bigmodel.cn 获取
OPENAI_MODEL=glm-4-flash                 # 文本模型（免费）
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# --- Vision LLM (智谱 GLM-4.6V-Flash — 多模态, 免费版) ---
VISION_MODEL=glm-4.6v-flash              # 视觉模型（免费）
VISION_API_KEY=${OPENAI_API_KEY}         # 默认与 OPENAI_API_KEY 相同
VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# --- Embedding (智谱 Embedding-2) ---
EMBEDDING_PROVIDER=openai               # 固定值，勿改
EMBEDDING_MODEL=embedding-2             # 智谱文本向量模型
EMBEDDING_API_KEY=${OPENAI_API_KEY}     # 默认与 OPENAI_API_KEY 相同
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# --- CLIP 图片向量 ---
CLIP_MODEL_NAME=ViT-B/32                # CLIP 模型（首次运行自动下载）
CLIP_DEVICE=cpu                          # cpu 或 cuda

# --- ChromaDB 向量数据库 ---
CHROMA_PERSIST_DIR=./chroma_data        # 数据持久化目录
TEXT_COLLECTION_NAME=text_collection     # 文本 Collection 名
IMAGE_COLLECTION_NAME=image_collection   # 图片 Collection 名

# --- 文本分块 ---
CHUNK_MAX_TOKENS=512                    # 最大 Token 数/块
CHUNK_OVERLAP_TOKENS=50                 # 块间重叠 Token 数

# --- RAG 检索参数 ---
RAG_TOP_K=5                             # 文本检索 Top-K
RAG_TOP_M=3                             # 图片检索 Top-M

# --- 图片处理 ---
IMAGE_MAX_DIMENSION=512                 # 图片最大边长（像素）
IMAGE_SAVE_DIR=./data/images            # 提取图片保存目录

# --- 实验评估 ---
EXPERIMENT_MAX_CONCURRENCY=5            # 并发上限
EXPERIMENT_DEFAULT_TEST_CASES=20        # 默认测试用例数
EXPERIMENT_DATA_DIR=./data/experiments  # 实验数据保存目录
